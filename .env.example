BOT_TOKEN=
# Telegram user id of the single owner who receives requests and uses the
# Owner panel. REQUIRED in production. When unset, owner features fall back
# to user id 1 (dev/test only) — set this for any real deployment.
BOT_OWNER_ID=
# Optional: Redis URL for durable storage. When set, arrangement requests,
# terms/questions config, and owner notifications persist in Redis; otherwise
# the toolkit's in-memory adapter is used (dev/test).
REDIS_URL=
