[
  {
    "name": "end-to-end: group trigger to owner processing",
    "steps": [
      {
        "send": { "text": "/arrange" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Let's take this to a private chat to keep your details private. Tap below to continue."
            }
          }
        ]
      },
      {
        "send": { "callback": "private:start" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Got it, Test. Let's set up your request.\n\n1. What is the arrangement for?"
            }
          }
        ]
      },
      {
        "send": { "text": "A meeting" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": { "text": "2. Add any details." }
          }
        ]
      },
      {
        "send": {
          "update": {
            "update_id": 40,
            "message": {
              "message_id": 401,
              "date": 0,
              "chat": { "id": 1, "type": "private", "first_name": "Test" },
              "from": { "id": 1, "is_bot": false, "first_name": "Test" },
              "document": { "file_id": "AgACQR1file", "file_name": "notes.pdf" }
            }
          }
        },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "📎 Attachment saved (1 so far).\n\n2. Add any details."
            }
          }
        ]
      },
      {
        "send": { "text": "Room 3" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "📋 Please review the terms:\n\nBy submitting, you confirm the details you provided are accurate. Your request is shared only with the owner, who will review and act on it.\n\nType 'I accept' to confirm and submit your request."
            }
          }
        ]
      },
      {
        "send": { "text": "I accept" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "📋 New arrangement request\n\nFrom: Test\n\n1. What is the arrangement for?\n   A meeting\n2. Add any details.\n   Room 3\n\n📎 Attachments: 1\n✅ Terms accepted"
            }
          },
          {
            "method": "sendMessage",
            "payload": {
              "text": "✅ Your request was submitted. The owner will review it."
            }
          }
        ]
      },
      {
        "send": { "callback": "owner:mark_processed" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": { "text": "✅ Marked as processed." }
          }
        ]
      }
    ]
  }
]
