[
  {
    "name": "owner sets custom terms then restores the default",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": { "text": "👋 Welcome! Tap a button below to get started." }
          }
        ]
      },
      {
        "send": { "callback": "owner:panel" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": { "text": "🛠 Owner panel — manage arrangement requests." }
          }
        ]
      },
      {
        "send": { "callback": "owner:set_terms" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": { "text": "📝 Send the new terms text." }
          }
        ]
      },
      {
        "send": { "text": "Custom terms here." },
        "expect": [
          {
            "method": "sendMessage",
            "payload": { "text": "✅ Terms updated." }
          }
        ]
      },
      {
        "send": { "callback": "owner:panel" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": { "text": "🛠 Owner panel — manage arrangement requests." }
          }
        ]
      },
      {
        "send": { "callback": "owner:set_terms" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": { "text": "📝 Send the new terms text." }
          }
        ]
      },
      {
        "send": { "text": "By submitting, you confirm the details you provided are accurate. Your request is shared only with the owner, who will review and act on it." },
        "expect": [
          {
            "method": "sendMessage",
            "payload": { "text": "✅ Terms updated." }
          }
        ]
      }
    ]
  }
]
