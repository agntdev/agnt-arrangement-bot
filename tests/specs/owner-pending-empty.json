[
  {
    "name": "owner pending view shows the empty state",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": { "text": "👋 Welcome! Tap a button below to get started." }
          }
        ]
      },
      {
        "send": { "callback": "owner:panel" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": { "text": "🛠 Owner panel — manage arrangement requests." }
          }
        ]
      },
      {
        "send": { "callback": "owner:pending" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "📭 No pending requests — they'll show up here when someone submits one."
            }
          }
        ]
      }
    ]
  }
]
